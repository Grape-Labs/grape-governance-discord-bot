DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
DISCORD_CHANNEL_ID=YOUR_CHANNEL_ID

# Option A (recommended): monitor multiple DAOs with one bot/channel.
# Format per entry: REALM_PUBKEY@PROGRAM_NAMESPACE@OPTIONAL_LABEL
# Separate multiple entries with semicolons.
# Example with two DAOs:
# DAO_TARGETS=By2sVGZXwfQq6rAiAM3rNPJ9iQfb5e2QhnF4YjJ4Bip@GovER5Lthms3bLBqWub97yVrMmEogzX7xNjdXpPPCVZw@Grape DAO;66Du7mXgS2KMQBUk6m9h3TszMjqZqdWhsG3Duuf69VNW@J9uWvULFL47gtCPvgR3oN7W357iehn5WF2Vn9MJvcSxz@Orca
DAO_TARGETS=

# Option B (legacy single DAO mode): if DAO_TARGETS is empty, these are used.
REALM_PUBKEY=By2sVGZXwfQq6rAiAM3rNPJ9iQfb5e2QhnF4YjJ4Bip

# SPL Governance program namespace used by Shyft GraphQL
GOV_PROGRAM_NAMESPACE=GovER5Lthms3bLBqWub97yVrMmEogzX7xNjdXpPPCVZw
SHYFT_GRAPHQL_URL=https://grape.shyft.to/v1/graphql/

POLL_INTERVAL_MS=30000
PROPOSAL_SCAN_LIMIT=1200
STATE_FILE=.bot-state/grape-proposal-state.json

# If false, first startup seeds state silently with no retroactive alerts.
ANNOUNCE_EXISTING_ON_START=false

# If true, bot tries to fetch description text from descriptionLink.
FETCH_DESCRIPTION_FROM_LINK=true
